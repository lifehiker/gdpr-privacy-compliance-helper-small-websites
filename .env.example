# App URL
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# NextAuth secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Stripe (optional - app works without these)
# STRIPE_SECRET_KEY="sk_live_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
# STRIPE_PRO_YEARLY_PRICE_ID="price_..."
# STRIPE_AGENCY_MONTHLY_PRICE_ID="price_..."
# STRIPE_AGENCY_YEARLY_PRICE_ID="price_..."

# Resend (optional - app works without this)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="noreply@yourdomain.com"

# S3 Storage (optional - evidence uploads need this)
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_S3_BUCKET="your-bucket-name"
# AWS_REGION="us-east-1"
# AWS_S3_ENDPOINT="https://..."  # Only needed for R2/MinIO; omit for standard AWS S3

# Cron job security (optional - protects /api/cron/weekly-digest)
# CRON_SECRET="generate-with-openssl-rand-base64-32"
